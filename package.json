{
  "name": "xi.tutor",
  "private": true,
  "scripts": {
    "install:ci": "pnpm install --ignore-scripts && pnpm run prepare",
    "build": "turbo run build --no-daemon",
    "build:debug": "pnpm --filter xi.web build:debug",
    "build:dev": "pnpm --filter xi.web build:dev",
    "dev": "pnpm --filter xi.web dev",
    "dev:all": "turbo run dev --concurrency 30",
    "preview": "pnpm --filter xi.web preview",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format-check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "prepare": "husky",
    "calls:deps:npm": "node packages/modules.calls/scripts/switch-calls-deps.mjs npm && pnpm install",
    "calls:deps:link": "node packages/modules.calls/scripts/switch-calls-deps.mjs link && pnpm install"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "husky": "^9.1.6",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.4.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "core-js"
    ],
    "overrides": {
      "@tiptap/core": "3.23.6",
      "@tiptap/pm": "3.23.6",
      "@tiptap/react": "3.23.6",
      "@tiptap/starter-kit": "3.23.6",
      "@tiptap/extensions": "3.23.6",
      "@xipkg/calls": "^0.1.8",
      "@xipkg/calls-chat": "^0.1.8",
      "@xipkg/calls-compactview": "^0.1.8",
      "@xipkg/calls-config": "^0.1.8",
      "@xipkg/calls-hooks": "^0.1.8",
      "@xipkg/calls-providers": "^0.1.8",
      "@xipkg/calls-risehand": "^0.1.8",
      "@xipkg/calls-store": "^0.1.8",
      "@xipkg/calls-types": "^0.1.8",
      "@xipkg/calls-ui": "^0.1.8",
      "@xipkg/calls-utils": "^0.1.8"
    }
  }
}
