{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sovlium",
  "version": "0.0.0",
  "identifier": "ru.sovlium.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm run dev:frontend",
    "beforeBuildCommand": "pnpm run build:frontend"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Sovlium",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "category": "Education",
    "copyright": "Copyright \u00a9 Sovlium",
    "publisher": "Sovlium",
    "shortDescription": "Sovlium native shell",
    "longDescription": "Sovlium is a learning platform. This is the native shell built on Tauri v2.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://releases.sovlium.ru/desktop/{{target}}/{{arch}}/{{current_version}}"
      ]
    },
    "deep-link": {
      "desktop": {
        "schemes": ["sovlium"]
      }
    }
  }
}
