# Dev-only overrides for the Tauri shell.
#
# Problem: in `tauri dev` the WebView loads from http://localhost:1420.
# The backend only allows specific production origins, so direct XHR to
# https://api.sovlium.ru fails with CORS 401.
#
# Fix: empty base URLs → Axios builds relative paths (/api/...) →
# Vite dev server proxies them server-side (no browser Origin header).
# In production the WebView uses the tauri:// scheme, so CORS is never
# an issue and absolute URLs from .env are used.
VITE_SERVER_URL_BACKEND=
VITE_SERVER_URL_SOCKETIO=
# Hocus (Yjs) goes through the Vite WebSocket proxy. The path `/hocus` is
# stripped before forwarding to wss://hocus.sovlium.ru/...
VITE_SERVER_URL_HOCUS=ws://localhost:1420/hocus
